{
  "expo": {
    "name": "The Well",
    "slug": "thewell",
    "newArchEnabled": true,
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "thewell",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C4B5FD"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thewell.dating.the-wellapp",
      "infoPlist": {
        "NSCameraUsageDescription": "The Well needs access to your camera to record your video story.",
        "NSMicrophoneUsageDescription": "The Well needs access to your microphone to record audio for your video story.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C4B5FD"
      },
      "package": "com.thewell.thewellapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow The Well to access your camera to share your story.",
          "microphonePermission": "Allow The Well to access your microphone to record audio.",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-video",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 28
          },
          "ios": {
            "deploymentTarget": "26.0",
            "flipper": false,
            "hermes": true
          }
        }
      ],
      "./plugins/with-fix-square-frameworks.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cced6652-8295-42b0-b9b4-8c0e6d5e770b"
      },
      "router": {
        "origin": "https://api.the-wellapp.com"
      }
    },
    "owner": "anointed-innovations"
  }
}
