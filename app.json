{
  "expo": {
    "name": "The Well",
    "slug": "thewell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "thewell",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C4B5FD"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thewell",
      "infoPlist": {
        "NSCameraUsageDescription": "The Well needs access to your camera to record your video story.",
        "NSMicrophoneUsageDescription": "The Well needs access to your microphone to record audio for your video story."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C4B5FD"
      },
      "package": "com.thewell",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow The Well to access your camera to share your story.",
          "microphonePermission": "Allow The Well to access your microphone to record audio.",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cced6652-8295-42b0-b9b4-8c0e6d5e770b"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "anointed-innovations"
  }
}
